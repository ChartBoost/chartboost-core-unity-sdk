{
  "metadata": [
    {
      "src": [
        {
          "src": "../../com.chartboost.core.canary",
          "files": [
            "**/com.chartboost.core.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "./filterConfig.yml"
    }
  ],
  "build": {
    "xref": [
      "https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml"
    ],
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "Chartboost Core Unity SDK",
      "_appTitle": "Chartboost Core Unity SDK",
      "_enableSearch": true,
      "pdf": true
    }
  }
}
